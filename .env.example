# Copy this file to .env and fill in your translation provider settings.
# These values act as app-wide defaults. `/api/books/{book_id}/translate` and
# `/api/books/{book_id}/resume` can override them per request.
# If you want multiple selectable provider profiles, keep the legacy block below
# or switch to the multi-profile example at the bottom.

FANBOOK_TRANSLATION_PROVIDER=openai
FANBOOK_TRANSLATION_MODEL=gpt-5.4
FANBOOK_TRANSLATION_BASE_URL=https://api.openai.com
# Explicitly setting FANBOOK_TRANSLATION_RUNTIME_PROFILE pins the runtime preset
# and disables automatic capability-based profile detection for this config.
# Leave it empty when you want the system to auto-pick a generic_* profile.
FANBOOK_TRANSLATION_RUNTIME_PROFILE=novel_consistency
FANBOOK_TRANSLATION_DETECTED_CONTEXT_WINDOW=
FANBOOK_TRANSLATION_STRUCTURED_OUTPUT_STRENGTH=
FANBOOK_TRANSLATION_REASONING_MODE=
FANBOOK_TRANSLATION_API_MODE=
FANBOOK_TRANSLATION_API_KEY=
FANBOOK_TRANSLATION_REASONING_EFFORT=low
FANBOOK_TRANSLATION_TIMEOUT_SECONDS=90
FANBOOK_TRANSLATION_ENDPOINT_CAPABILITY_DETECTION_ENABLED=true
FANBOOK_TRANSLATION_ENDPOINT_CAPABILITY_DETECTION_TIMEOUT_SECONDS=5
FANBOOK_TRANSLATION_ENDPOINT_CAPABILITY_DETECTION_TTL_SECONDS=1800
FANBOOK_TRANSLATION_MAX_REQUESTS_PER_MINUTE=
FANBOOK_TRANSLATION_MAX_CONCURRENCY=
FANBOOK_TRANSLATION_PER_CHAPTER_CONCURRENCY=
FANBOOK_TRANSLATION_MIN_PER_CHAPTER_CONCURRENCY=
FANBOOK_TRANSLATION_ADAPTIVE_PER_CHAPTER_CONCURRENCY=true
FANBOOK_TRANSLATION_MAX_INPUT_TOKENS=
FANBOOK_TRANSLATION_RESERVED_OUTPUT_TOKENS=
FANBOOK_TRANSLATION_MAX_OUTPUT_TOKENS=
FANBOOK_TRANSLATION_CHUNK_TARGET_TOKENS=
FANBOOK_TRANSLATION_CONTEXT_SEGMENTS_BEFORE=3
FANBOOK_TRANSLATION_CONTEXT_SEGMENTS_AFTER=1
FANBOOK_TRANSLATION_MEMORY_SIZE=8
FANBOOK_TRANSLATION_RETRY_MAX_ATTEMPTS=3

# Optional compatibility variables:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com

# Optional multi-profile example:
# FANBOOK_TRANSLATION_PROFILES=fast,cheap
# FANBOOK_TRANSLATION_DEFAULT_PROFILE=fast
#
# FANBOOK_TRANSLATION_PROFILE_FAST_PROVIDER=openai
# FANBOOK_TRANSLATION_PROFILE_FAST_MODEL=gpt-5.4
# FANBOOK_TRANSLATION_PROFILE_FAST_RUNTIME_PROFILE=generic_large_context
# FANBOOK_TRANSLATION_PROFILE_FAST_BASE_URL=https://api.openai.com
# FANBOOK_TRANSLATION_PROFILE_FAST_API_MODE=responses
# FANBOOK_TRANSLATION_PROFILE_FAST_API_KEY=
# FANBOOK_TRANSLATION_PROFILE_FAST_REASONING_EFFORT=low
# FANBOOK_TRANSLATION_PROFILE_FAST_ENDPOINT_CAPABILITY_DETECTION_ENABLED=true
# FANBOOK_TRANSLATION_PROFILE_FAST_MAX_REQUESTS_PER_MINUTE=
# FANBOOK_TRANSLATION_PROFILE_FAST_MAX_CONCURRENCY=24
# FANBOOK_TRANSLATION_PROFILE_FAST_PER_CHAPTER_CONCURRENCY=8
# FANBOOK_TRANSLATION_PROFILE_FAST_MIN_PER_CHAPTER_CONCURRENCY=2
#
# FANBOOK_TRANSLATION_PROFILE_CHEAP_PROVIDER=openai
# FANBOOK_TRANSLATION_PROFILE_CHEAP_MODEL=deepseek-chat
# FANBOOK_TRANSLATION_PROFILE_CHEAP_RUNTIME_PROFILE=generic_rate_limited
# FANBOOK_TRANSLATION_PROFILE_CHEAP_BASE_URL=https://api.openai.com
# FANBOOK_TRANSLATION_PROFILE_CHEAP_API_MODE=chat_completions
# FANBOOK_TRANSLATION_PROFILE_CHEAP_API_KEY=
# FANBOOK_TRANSLATION_PROFILE_CHEAP_REASONING_EFFORT=low
# FANBOOK_TRANSLATION_PROFILE_CHEAP_ENDPOINT_CAPABILITY_DETECTION_TTL_SECONDS=1800
# FANBOOK_TRANSLATION_PROFILE_CHEAP_MAX_REQUESTS_PER_MINUTE=30
# FANBOOK_TRANSLATION_PROFILE_CHEAP_MAX_CONCURRENCY=10
# FANBOOK_TRANSLATION_PROFILE_CHEAP_PER_CHAPTER_CONCURRENCY=4
# FANBOOK_TRANSLATION_PROFILE_CHEAP_MIN_PER_CHAPTER_CONCURRENCY=1

# Built-in runtime profiles:
# - generic_safe
# - generic_large_context
# - generic_low_latency
# - generic_reasoning
# - generic_rate_limited
# - novel_consistency
#
# If *_RUNTIME_PROFILE is explicitly set, that preset wins before auto-detection.
# Leave *_RUNTIME_PROFILE empty when you want model/endpoint capability detection
# to choose a generic_* profile automatically.
# Leave concurrency/token fields empty to follow the selected runtime profile.
# Fill them only when you want an explicit numeric override.

# Optional runtime overrides:
# FANBOOK_RUNTIME_ROOT=D:/1something/fanbook/temp/.fanbook-runtime
# FANBOOK_FRONTEND_ROOT=D:/1something/fanbook/frontend
